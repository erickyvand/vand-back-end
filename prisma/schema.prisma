// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["Authentication", "Content"]
}

enum UserType {
  Internal
  External

  @@schema("Authentication")
}

enum Language {
  en
  fr
  rw

  @@schema("Authentication")
}

// Shared base — everyone
model User {
  id            String      @id @default(cuid())
  fullName      String
  slug          String      @unique
  email         String      @unique
  phone         String?     @unique
  password      String
  userType      UserType
  language      Language    @default(rw)
  isActive      Boolean     @default(true)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  loginCount    Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  deletedAt     DateTime?

  // Relations to extensions
  internalProfile   InternalProfile?
  externalProfile   ExternalProfile?
  roles      Role[]

  @@map("Users")
  @@schema("Authentication")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  displayName String
  createdById String?
  createdBy   User?    @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Opposite relations
  internalProfiles InternalProfile[]
  externalProfiles ExternalProfile[]

  @@map("Roles")
  @@schema("Authentication")
}

// Internal-specific fields
model InternalProfile {
  id                 String       @id @default(cuid())
  userId             String       @unique
  user               User         @relation(fields: [userId], references: [id])
  roleId             String
  role               Role         @relation(fields: [roleId], references: [id])
  mustChangePassword Boolean      @default(true)
  lastPasswordChange DateTime?
  twoFactorEnabled   Boolean      @default(false)
  twoFactorSecret    String?
  isSuspended        Boolean      @default(false)
  suspendedReason    String?
  suspendedAt        DateTime?
  suspendedBy        String?
  createdBy          String?
  avatar             String?
  bio                String?
  timezone           String       @default("Africa/Kigali")
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  articles           Article[]
  uploadedMedia      Media[]

  @@map("InternalProfiles")
  @@schema("Authentication")
}

model ExternalProfile {
  id            String        @id @default(cuid())
  userId        String        @unique
  user          User          @relation(fields: [userId], references: [id])
  roleId        String
  role          Role          @relation(fields: [roleId], references: [id])
  isVerified    Boolean       @default(false)
  avatar        String?
  bio           String?
  location      String?
  interests     String[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("ExternalProfiles")
  @@schema("Authentication")
}

model Category {
  id            String   @id @default(cuid())
  groupId       String
  slug          String
  language      Language
  name          String
  description   String?
  image         String?
  isActive      Boolean  @default(true)
  parentGroupId String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  articles Article[]

  @@unique([slug, language])
  @@unique([groupId, language])
  @@map("Categories")
  @@schema("Content")
}

enum ArticleStatus {
  Draft
  InReview
  Published
  Rejected
  Archived

  @@schema("Content")
}

enum FeaturedType {
  Hero
  Secondary
  Spotlight

  @@schema("Content")
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     Json
  thumbnailId String?
  thumbnail   Media?          @relation(fields: [thumbnailId], references: [id])
  language    Language
  status      ArticleStatus @default(Draft)
  publishedAt DateTime?
  viewCount    Int           @default(0)
  featuredType  FeaturedType?
  featuredAt    DateTime?
  isBreaking    Boolean       @default(false)
  breakingUntil DateTime?

  categoryId  String
  category    Category        @relation(fields: [categoryId], references: [id])
  authorId    String
  author      InternalProfile @relation(fields: [authorId], references: [id])

  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  tags        ArticleTag[]
  comments    Comment[]

  @@map("Articles")
  @@schema("Content")
}

model Tag {
  id           String           @id @default(cuid())
  name         String           
  slug         String           @unique
  articles     ArticleTag[]
  translations TagTranslation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@map("Tags")
  @@schema("Content")
}

model TagTranslation {
  id       String   @id @default(cuid())
  tagId    String
  language Language
  label    String
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, language])
  @@unique([label, language])
  @@map("TagTranslations")
  @@schema("Content")
}

model ArticleTag {
  articleId String
  tagId     String
  article   Article @relation(fields: [articleId], references: [id])
  tag       Tag     @relation(fields: [tagId], references: [id])

  @@id([articleId, tagId])
  @@map("ArticleTags")
  @@schema("Content")
}

model Media {
  id          String          @id @default(cuid())
  url         String
  filename    String
  mimeType    String
  size        Int
  uploadedBy  String
  uploader    InternalProfile @relation(fields: [uploadedBy], references: [id])
  createdAt   DateTime        @default(now())

  articles    Article[]

  @@map("Media")
  @@schema("Content")
}

model Comment {
  id          String   @id @default(cuid())
  content     String
  authorName  String
  authorEmail String
  articleId   String
  article     Article  @relation(fields: [articleId], references: [id])
  userId      String?
  createdAt   DateTime @default(now())

  @@map("Comments")
  @@schema("Content")
}
